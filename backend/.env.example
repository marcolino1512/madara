# =============================================
# Configurações do Banco de Dados PostgreSQL
# =============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# =============================================
# Configurações do JWT (Token de Autenticação)
# =============================================
# Gere uma string aleatória e segura para o secret
JWT_SECRET=troque_para_uma_chave_secreta_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# =============================================
# Configurações do Servidor
# =============================================
PORT=3000

# =============================================
# URLs para CORS (produção)
# Preencha após criar o projeto no Vercel e
# configurar o domínio estático no ngrok.
# =============================================
FRONTEND_URL=https://seu-projeto.vercel.app
NGROK_URL=https://seu-dominio.ngrok-free.app
